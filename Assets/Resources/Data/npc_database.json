        { "timeSlot": "Afternoon", "location": "操场" },
        { "timeSlot": "Evening",   "location": "宿舍" }
      ],
      "greetingLines": [
        "哟，来了。坐，随便坐。",
        "（打了个哈欠）今天也是平和的一天呢。",
        "有啥事儿？没事儿就一起摸鱼吧。"
      ]
    },
    {
      "id": "NPC_Senior",
      "displayName": "谢凌云",
      "type": "Senior",
      "personality": "Mysterious",
      "description": "传说中的全能学长/学姐，成绩优异、社交广泛，却总是神出鬼没。",
